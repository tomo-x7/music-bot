		"build": "esbuild src/main.ts --bundle --packages=external --platform=node --format=esm --target=node24 --outfile=dist/index.js"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"devDependencies": {
		"@biomejs/biome": "2.2.3",
		"@types/node": "^25.4.0",
		"esbuild": "^0.27.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@discordjs/opus": "^0.10.0",
		"@discordjs/voice": "^0.19.1",
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"uuid": "^13.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@discordjs/opus",
			"esbuild"
